APP_NAME=async-payment-processor
API_KEY=local-dev-key
DATABASE_URL=postgresql+asyncpg://payment:payment@postgres:5432/payments
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_EXCHANGE=payments
RABBITMQ_MAIN_QUEUE=payments.new
RABBITMQ_RETRY_QUEUES=["payments.new.retry.1","payments.new.retry.2"]
RABBITMQ_DLQ=payments.dlq
OUTBOX_BATCH_SIZE=50
OUTBOX_POLL_INTERVAL_SECONDS=1.0
WEBHOOK_TIMEOUT_SECONDS=5.0
WEBHOOK_MAX_DELIVERY_ATTEMPTS=3
WEBHOOK_RETRY_DELAYS_SECONDS=[2,4]
GATEWAY_CLAIM_TIMEOUT_SECONDS=30.0
WEBHOOK_CLAIM_TIMEOUT_SECONDS=30.0
WORKER_HEARTBEAT_FILE_CONSUMER=/tmp/consumer-heartbeat
WORKER_HEARTBEAT_FILE_OUTBOX_RELAY=/tmp/outbox-relay-heartbeat
WORKER_HEARTBEAT_INTERVAL_SECONDS=5.0
PAYMENT_GATEWAY_MIN_DELAY_SECONDS=2.0
PAYMENT_GATEWAY_MAX_DELAY_SECONDS=5.0
PAYMENT_GATEWAY_SUCCESS_RATE=0.9
LOG_LEVEL=INFO
